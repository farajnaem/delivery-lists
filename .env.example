APP_NAME=كشوفات التسليم
APP_URL=https://delivery.example.com
APP_DEBUG=false
APP_TIMEZONE=Asia/Riyadh
# مفتاح ثابت لتوقيع جلسات تطبيق المخزن — إلزامي في Coolify وإلا تنقطع كل الجوالات بعد كل Redeploy
# ولّده مرة واحدة واحفظه ولا تغيّره: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=
# اختياري عند تدوير المفتاح: ضع القيمة القديمة مؤقتاً حتى يسجّل الجميع دخولاً جديداً
# PREVIOUS_APP_KEY=

# === قاعدة البيانات (Coolify) ===
# الطريقة 1 — انسخ DATABASE_URL بعد ربط MySQL بالتطبيق:
# DATABASE_URL=mysql://mysql:PASSWORD@mysql-xxxxx:3306/default

# الطريقة 2 — متغيرات Coolify التلقائية عند ربط MySQL:
# DB_DRIVER=mysql

# === SQLite (تطوير محلي فقط — لا يُنصَح للإنتاج بدون volume) ===
DB_DRIVER=sqlite
DB_PATH=database/delivery.sqlite

# DB_DRIVER=mysql
# DB_HOST=mysql-xxxxx
# DB_PORT=3306
# DB_NAME=delivery_lists
# DB_USER=mysql
# DB_PASS=

# SMS (اختياري)
SMS_ENABLED=false
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=
